# Live data — football-data.org
#
# Optional. Without it the app runs on the bundled static snapshot (see
# src/lib/data.js). With a valid key, loadFixtures() pulls live World Cup match
# results and the masthead shows a "LIVE" indicator.
#
# Setup:
#   1. Register for a free key at https://www.football-data.org/client/register
#   2. Copy this file to `.env` (which is gitignored):  cp .env.example .env
#   3. Paste your key below and restart the dev server (`npm run dev`).
#
# NOTE: this is intentionally NOT prefixed with VITE_. VITE_-prefixed vars are
# inlined into the client bundle and would leak the key to anyone viewing source.
# This key is read only by vite.config.js and injected server-side by the proxy.
FOOTBALL_DATA_API_KEY=

# Player headshots — Google Custom Search (image)
#
# Optional. Without both values the app shows ESPN headshots (~4% of players) and
# initials for everyone else. With them, most players resolve to a real photo via
# the /photo-api proxy (dev: vite.config.js · prod: api/photo.js), which caches
# results per player in the browser's localStorage.
#
# Setup:
#   1. Get an API key: https://developers.google.com/custom-search/v1/overview
#   2. Create a Custom Search Engine (search the whole web) and copy its ID
#      ("cx"): https://cse.google.com/cse/
#   3. Paste both below and restart the dev server (`npm run dev`).
#
# NOTE: like the football-data key, these are intentionally NOT VITE_-prefixed —
# they are read only server-side by the proxy and never reach the browser bundle.
GOOGLE_CUSTOM_SEARCH_KEY=
GOOGLE_CUSTOM_SEARCH_ENGINE_ID=
