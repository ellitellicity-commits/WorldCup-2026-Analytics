{
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/football-api/:path*", "destination": "/api?path=:path*" },
    { "source": "/photo-api", "destination": "/api/photo" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
